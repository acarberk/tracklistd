{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@tracklistd/config/tsconfig/nextjs.json",
  "compilerOptions": {
    "outDir": ".next",
    "rootDir": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
