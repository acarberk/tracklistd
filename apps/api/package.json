{
  "name": "@tracklistd/api",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS backend API",
  "scripts": {
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "dotenv -e ../../.env -- tsc-watch -p tsconfig.build.json --onSuccess \"node dist/main.js\"",
    "test": "echo 'no tests yet'",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "prisma:format": "dotenv -e ../../.env -- prisma format",
    "prisma:migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:reset": "dotenv -e ../../.env -- prisma migrate reset",
    "prisma:studio": "dotenv -e ../../.env -- prisma studio"
  },
  "devDependencies": {
    "@tracklistd/config": "workspace:*",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.24.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "tsc-watch": "^7.2.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/terminus": "^11.1.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  }
}
